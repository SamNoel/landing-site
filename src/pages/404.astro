---
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionContainer from "@components/containers/SectionContainer.astro";
import Stack from "@components/primitives/Stack.astro";
import PageContainer from "@components/containers/PageContainer.astro";
import BackgroundImage from "@assets/background-transparent.png";
import Heading from "@components/primitives/Heading.astro";
import Text from "@components/primitives/Text.astro";

export const prerender = true;
---

<BaseLayout title="404">
  <PageContainer id="404" class="notfound-container">
    <SectionContainer style="display: flex; justify-content: center;">
      <Stack
        direction="column"
        gap="lg"
        justify="center"
        align="center"
        style="max-width: 400px;"
      >
        <Heading titleSize="h1" display={true}>404</Heading>
        <Text align="center"
          >Looks like the page you're looking for doesn't exist. Please check
          the URL or return to the homepage using the link below.</Text
        >
        <a href="/">Back to home</a>
      </Stack>
    </SectionContainer>
  </PageContainer>
</BaseLayout>

<style define:vars={{ backgroundImage: `url(${BackgroundImage.src})` }}>
  .notfound-container {
    background-image: url(/src/assets/background-transparent.png); /*var(--backgroundImage); */
    background-position: right bottom;
    background-repeat: no-repeat;
    background-size: contain;
    background-attachment: fixed;
  }

  @media (max-width: 768px) {
    .notfound-container {
      background-image: url(/src/assets/background-mobile-transparent.png); /*var(--backgroundImage); */
      background-position: center top;
      background-repeat: no-repeat;
      background-size: contain;
      background-attachment: scroll;
    }
  }
</style>
