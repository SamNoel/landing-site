---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/composits/Hero.astro";
import SectionContainer from "@components/containers/SectionContainer.astro";
import Stack from "@components/primitives/Stack.astro";
import Divider from "@components/primitives/Divider.astro";
import { getAbout } from "@services/loaders/pages/home/about";
import PageContainer from "@components/containers/PageContainer.astro";
import BackgroundImage from "@assets/background-transparent.png";
import Button from "@components/primitives/Button.astro";

// const servicesCollection = await getServices();
// const reviewsCollection = await getReviews();
const aboutContent = await getAbout();
---

<BaseLayout title="Home">
  <PageContainer id="home" class="homepage-container">
    <SectionContainer>
      <Hero />
    </SectionContainer>

    <SectionContainer>
      <Divider />
    </SectionContainer>

    <!-- <Button href="#" label="Click Here" variant="primary" /> -->

    <SectionContainer class="about-section fade-in-element" id="about">
      <Stack
        direction="row"
        gap="md"
        horizontalAlign="center"
        verticalAlign="top"
      >
        <h2>{aboutContent.title}</h2>
        <div><aboutContent.Content /></div>
      </Stack>
    </SectionContainer>

    <SectionContainer>
      <Divider />
    </SectionContainer>

    <SectionContainer id="contact">
      <Stack
        direction="row"
        gap="md"
        horizontalAlign="center"
        verticalAlign="top"
      >
        <Stack
          direction="column"
          gap="md"
          horizontalAlign="left"
          verticalAlign="top"
        >
          <h2>Get In Touch</h2>
          <p>
            If you are looking for web services and think we could be a good
            fit, don't hesitate to reach out via phone or email - or fill out
            the form to get in touch!
          </p>
        </Stack>
        <!-- <div><aboutContent.Content/></div> -->
      </Stack>
    </SectionContainer>

    <!-- <SectionContainer>
		<Stack
		direction="column"
					gap="md"
					horizontalAlign="left"
					verticalAlign="top"
		>
			<h2>What Our Customers Are Saying…</h2>
			<Grid columns={3}>
				{reviewsCollection.map((review) => (
					<Stack
					direction="column"
					gap="sm"
					horizontalAlign="left"
					verticalAlign="top"
					>
						<h3>{review.name}</h3>
						<p>{review.review}</p>
						{/* <p><strong>- {review.author}</strong></p> */}
					</Stack>
				))}
			</Grid>
		</Stack>
	</SectionContainer> -->
  </PageContainer>
</BaseLayout>

<style define:vars={{ backgroundImage: `url(${BackgroundImage.src})` }}>
  .homepage-container {
    background-image: url(/src/assets/background-transparent.png); /*var(--backgroundImage); */
    background-position: right bottom;
    background-repeat: no-repeat;
    background-size: contain;
    background-attachment: fixed;
  }

  .about-section {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 32px;
  }

  @media (max-width: 768px) {
    .homepage-container {
      background-image: url(/src/assets/background-mobile-transparent.png); /*var(--backgroundImage); */
      background-position: center top;
      background-repeat: no-repeat;
      background-size: contain;
      background-attachment: scroll;
    }
  }

  /* 1. Define the fade-in animation keyframes */
  /* =========================
   ANIMATIONS
========================= */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(
        50px
      ); /* Optional: slides up slightly while fading */
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 2. Apply it to your target scroll elements */
  .fade-in-element {
    /* Attach the keyframe animation */
    animation: fadeIn ease-in-out both;

    /* Bind the animation progress directly to the element entering the viewport */
    animation-timeline: view();

    /* Adjust exactly when the animation starts and finishes */
    /* Starts when the top of the element hits the bottom of the viewport */
    /* Ends when the element is 30% into the viewport */
    animation-range: entry 0% entry 30%;
  }
</style>
