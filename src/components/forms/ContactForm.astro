---
// import {PUBLIC_WEB3FORMS_ACCESS_KEY} from 'astro:env/client';
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  id="form"
  class="needs-validation contact-form max-wide"
  data-astro-reload
  novalidate
>
  <input
    type="hidden"
    name="access_key"
    value="92f04ba0-23e2-43c0-bbde-e883621269a0"
  />

  <input type="checkbox" class="hidden" style="display:none" name="botcheck" />
  <div class="field">
    <label for="full_name" class="cf_label">Name</label>
    <input
      id="full_name"
      type="text"
      placeholder="Full Name"
      required
      class="cf_input"
      name="name"
    />
    <div class="validation_message empty-feedback invalid-feedback">
      Please provide your full name.
    </div>
  </div>
  <div class="field">
    <label for="email_address" class="cf_label">Email Address</label>
    <input
      id="email_address"
      type="email"
      placeholder="Email Address"
      name="email"
      required
      class="cf_input"
    />
    <div class="validation_message empty-feedback invalid-feedback">
      Please provide your email address.
    </div>
    <div class="validation_message empty-feedback invalid-feedback">
      Please provide a valid email address.
    </div>
  </div>
  <div class="field">
    <label for="message" class="cf_label">Message</label>
    <textarea
      id="message"
      name="message"
      required
      placeholder="How can we help your business?"
      class="cf_input"></textarea>
    <div class="validation_message empty-feedback invalid-feedback">
      Please enter your message.
    </div>
  </div>
  <div class="h-captcha" data-captcha="true" data-theme="dark" data-lang="en">
  </div>
  <button type="submit" class="submit-btn button primary">Send Message</button>
  <div id="result" class="result_message"></div>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 2rem;
    background-color: var(--color-surface);
    width: 100%;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cf_label {
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--color-body-muted);
  }

  .cf_input {
    font-family: var(--font-noto-sans);
    font-size: var(--text-sm);
    font-weight: 300;
    color: #fff;
    background: #000;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.75rem 1rem;
    width: 100%;
    box-sizing: border-box;
    transition:
      border-color 150ms ease,
      background 150ms ease;
    resize: vertical;
  }

  .validation_message {
    font-size: var(--text-sm);
    color: red;
  }

  .result_message {
    font-size: var(--text-sm);
    color: var(--color-white);
  }

  input::placeholder,
  textarea::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  input:hover,
  textarea:hover {
    border-color: rgba(255, 255, 255, 0.3);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.03);
  }

  input[aria-invalid="true"],
  textarea[aria-invalid="true"] {
    border-color: rgba(255, 100, 100, 0.7);
  }

  /* ── Submit button ── */
  .submit-btn {
    font-family: var(--font-noto-sans);
    font-size: 1rem;
    font-weight: 500;
    color: #000;
    background: #fff;
    border: none;
    border-radius: 3px;
    padding: 1.5rem 1.75rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    text-align: center;
    justify-content: center;
    gap: 0.5rem;
    transition:
      background 150ms ease,
      color 150ms ease,
      opacity 150ms ease;
    white-space: nowrap;
  }

  .submit-btn:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.85);
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #dc3545;
  }
</style>

<script is:inline>
  // use astro:page-load event if you are using View Transitions

  document.addEventListener(
    "DOMContentLoaded",
    () => {
      const form = document.getElementById("form");
      const result = document.getElementById("result");

      form.addEventListener("submit", function (e) {
        e.preventDefault();
        form.classList.add("was-validated");
        if (!form.checkValidity()) {
          form.querySelectorAll(":invalid")[0].focus();
          return;
        }
        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        result.innerHTML = "Sending...";

        fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: json,
        })
          .then(async (response) => {
            let json = await response.json();
            if (response.status == 200) {
              result.classList.add("text-green-500");
              result.innerHTML =
                "Thanks for reaching out! We'll get back to you soon.";
            } else {
              console.log(response);
              result.classList.add("text-red-500");
              result.innerHTML = json.message;
            }
          })
          .catch((error) => {
            console.log(error);
            result.innerHTML = "Something went wrong!";
          })
          .then(function () {
            form.reset();
            form.classList.remove("was-validated");
            setTimeout(() => {
              result.style.display = "none";
            }, 5000);
          });
      });
    },
    { once: true },
  );
</script>

<script src="https://web3forms.com/client/script.js" async defer></script>
