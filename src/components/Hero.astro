---
import type { HeroProps } from "../lib/schemas/components/hero";

const { title, subtitle } = Astro.props as HeroProps;
---

<section class="hero">
  <h1>{title}</h1>
  <p>{subtitle}</p>
</section>

<style>
.hero {
  padding: var(--space-4) 0;
}

h1 {
  font-size: var(--text-2xl);
  margin: 0 0 var(--space-2);
}

p {
  color: var(--color-muted);
  font-size: var(--text-lg);
}
</style>