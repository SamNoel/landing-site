---
import type {GridProps} from "@props/grid";

const {
    columns = 4,
    gap = 16,
} = Astro.props as GridProps;

const {class: className = "grid", ...props} = Astro.props;
---

<div class={className} {...props} style={`--columns:${columns}; --gap:${gap}px;`}>
  <slot></slot>
</div>

<style>
.grid {
  display: grid;
  width: 100%;
  grid-template-columns: repeat(var(--columns), minmax(240px, 1fr));
  gap: var(--gap);
}

@media (max-width: 768px) {
  .grid {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
}
</style>