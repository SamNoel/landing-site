---
import type {CardProps} from "../lib/schemas/components/card";

const { title, text } = Astro.props as CardProps;
---

<div class="card">
  <h3>{title}</h3>
  <p>{text}</p>
</div>

<style>
.card {
  padding: var(--space-3);
  border: 1px solid #eee;
  border-radius: 8px;
}

h3 {
  margin-top: 0;
  margin-bottom: var(--space-1);
}

p {
  margin: 0;
  color: var(--color-muted);
}
</style>