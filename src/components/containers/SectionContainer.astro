---
const {
  itemAlign = 'center',
  gap = 'md'
} = Astro.props

const {class: className = "grid", ...props} = Astro.props;
---

<section class="section-container" {...props}>
  <slot />
</section>

<style>
.section-container {
  margin: 0;
  align-self: stretch;
  padding: 64px var(--space-4);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 24px;
  min-width: 0;
  max-width: 1200px;
}

@media (max-width: 768px) {
  .section-container {
    padding: 32px var(--space-2);
  }
}

</style>